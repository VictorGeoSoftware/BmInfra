# Copy this file to `.env` (same directory) and fill in real values.
#   cp .env.example .env
# The .env file is git-ignored and read automatically by docker compose.

# ─── Shared ───
# Postgres password for the bm_app role (PROD + QA share the same instance).
DB_PASSWORD=change-me-strong-password

# Backend PII encryption key — base64-encoded 32 bytes, AES-GCM.
# REQUIRED. Do NOT lose or change it once data is encrypted, or existing
# encrypted data becomes unreadable. Shared by PROD and QA backends.
# Generate one with:  openssl rand -base64 32
BM_ENCRYPTION_KEY=replace-with-base64-of-32-bytes

# ─── n8n basic-auth passwords ───
N8N_PROD_PASSWORD=change-me-n8n-prod
N8N_QA_PASSWORD=change-me-n8n-qa
